# このファイルを「secrets.toml」という名前でコピーして使います。
# （Streamlit Community Cloud の場合は、アプリ管理画面の「Settings → Secrets」に
#   下記の各行を貼り付けます。ローカルで試す場合はこのフォルダに secrets.toml を置きます）

# --- ログインパスワード（社外公開なら必須） ---
# 設定すると、正しいパスワードを入れた人だけが使えます。
app_password = "ここに好きなパスワードを入れる"

# --- データの保存先：Turso（クラウドDB） ---
# Turso(https://turso.tech) で無料DBを作成すると取得できる
# 「Database URL」と「Auth Token」をここに貼り付けます。
# 設定すると、データはクラウドDBに保存され、消えずに全社員で共有されます。
# 設定しない場合は、アプリと同じ場所の shayosha.db（ローカル）に保存されます。
turso_database_url = "libsql://あなたのDB名-組織名.turso.io"
turso_auth_token = "ここにTursoのAuth Tokenを貼り付け"
